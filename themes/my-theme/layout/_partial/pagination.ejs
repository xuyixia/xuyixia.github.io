<% if (page.prev || page.next) { %>
  <div class="pagination">
    <% if (page.prev) { %>
      <a href="<%- url_for(page.prev_link) %>">上一页</a>
    <% } %>
    <span class="page-number"><%= page.current %> / <%= page.total %></span>
    <% if (page.next) { %>
      <a href="<%- url_for(page.next_link) %>">下一页</a>
    <% } %>
  </div>
<% } %>